#!/usr/bin/env bash
set -euo pipefail

echo "[pre-push] Building site..."
bundle exec jekyll build

if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
  echo "[pre-push] Validating HTML..."
  docker run --rm \
    -v "$PWD/_site:/site" \
    ghcr.io/validator/validator:latest \
    vnu --errors-only --skip-non-html /site
else
  echo "[pre-push] WARN: Docker is unavailable, skipping vnu validation."
fi

echo "[pre-push] OK"
