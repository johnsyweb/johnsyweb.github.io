#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

if ! command -v mise >/dev/null 2>&1; then
  echo "mise is required. Install it from https://mise.jdx.dev" >&2
  exit 1
fi

if ! mise exec -- bundle check >/dev/null 2>&1; then
  echo "Ruby gems missing; installing before starting server..."
  mise exec -- bundle config set path "vendor/bundle"
  mise exec -- bundle install --jobs 4 --retry 3
fi

mise exec -- pnpm run dev